#include <rclcpp/rclcpp.hpp>
#include <sensor_msgs/msg/image.hpp>
#include <cv_bridge/cv_bridge.h>
#include <image_transport/image_transport.hpp>

// OpenCV 与 CUDA 核心头文件
#include <opencv2/opencv.hpp>
#include <cuda_runtime_api.h>
#include <NvInfer.h>

#include <fstream>
#include <iostream>
#include <vector>

using namespace nvinfer1;

// 1. 必须实现一个 TRT 的日志接收器 (TRT 规矩)
class Logger : public ILogger {
    void log(Severity severity, const char* msg) noexcept override {
        if (severity <= Severity::kWARNING) {
            std::cout << "[TRT] " << msg << std::endl;
        }
    }
} gLogger;

class YoloTrtNode : public rclcpp::Node {
public:
    YoloTrtNode() : Node("yolo_trt_node") {
        // --- 核心动作 1：声明话题 ---
        subscription_ = this->create_subscription<sensor_msgs::msg::Image>(
            "/camera/color/image_raw", 10,
            std::bind(&YoloTrtNode::image_callback, this, std::placeholders::_1));
        
        publisher_ = this->create_publisher<sensor_msgs::msg::Image>("/lekiwi_vision/yolo_image", 10);

        // --- 核心动作 2：极其优雅地读取外部 YAML 参数 ---
        // 1. 必须先“声明”参数，并给个兜底的默认值，防止没传 yaml 时程序直接崩溃
        this->declare_parameter<std::string>("engine_path", "default.engine");
        
        // 2. 从 ROS 2 参数服务器里把值“抠”出来
        std::string engine_path;
        this->get_parameter("engine_path", engine_path);

        RCLCPP_INFO(this->get_logger(), "✅ 成功读取配置文件，引擎路径: %s", engine_path.c_str());

        // 3. 点火！
        init_tensorrt_engine(engine_path);
        
        RCLCPP_INFO(this->get_logger(), "🚀 YOLO11 TensorRT 引擎挂载完毕，等待视频流...");
    }

    ~YoloTrtNode() {
        // 熄火：释放 GPU 显存，防止内存泄漏
        cudaFree(buffers_[0]);
        cudaFree(buffers_[1]);
    }

private:
    // ROS 2 核心通信组件
    rclcpp::Subscription<sensor_msgs::msg::Image>::SharedPtr subscription_;
    rclcpp::Publisher<sensor_msgs::msg::Image>::SharedPtr publisher_;

    // TensorRT 核心组件
    std::unique_ptr<IRuntime> runtime_;
    std::unique_ptr<ICudaEngine> engine_;
    std::unique_ptr<IExecutionContext> context_;
    void* buffers_[2]; // GPU 显存指针：[0]是输入图片，[1]是输出结果
    cudaStream_t stream_; // CUDA 异步流

    const int INPUT_W = 640;
    const int INPUT_H = 640;
    const int OUTPUT_SIZE = 8400 * 5; // YOLO11s 默认输出维度 (8400个框 * (4个坐标+1个置信度))

    // ==========================================
    // 第一斧：读取 .engine 文件，在 GPU 上挖坑
    // ==========================================
    void init_tensorrt_engine(const std::string& engine_path) {
        std::ifstream file(engine_path, std::ios::binary);
        if (!file.good()) {
            RCLCPP_ERROR(this->get_logger(), "找不到 Engine 文件！代驾小哥迷路了！");
            return;
        }

        // 把文件读到物理内存
        file.seekg(0, file.end);
        size_t size = file.tellg();
        file.seekg(0, file.beg);
        std::vector<char> trtModelStream(size);
        file.read(trtModelStream.data(), size);
        file.close();

        // 反序列化为 TRT 引擎
        runtime_.reset(createInferRuntime(gLogger));
        engine_.reset(runtime_->deserializeCudaEngine(trtModelStream.data(), size));
        context_.reset(engine_->createExecutionContext());

        // 在 GPU 上“挖”两块显存池（输入和输出）
        cudaMalloc(&buffers_[0], 1 * 3 * INPUT_H * INPUT_W * sizeof(float)); // 输入池
        cudaMalloc(&buffers_[1], 1 * OUTPUT_SIZE * sizeof(float));           // 输出池
        cudaStreamCreate(&stream_);
    }

    // ==========================================
    // 第二斧：视频流回调与极速推理
    // ==========================================
    void image_callback(const sensor_msgs::msg::Image::SharedPtr msg) {
        // 1. 将 ROS 图像无缝转换为 OpenCV 矩阵
        cv_bridge::CvImagePtr cv_ptr;
        try {
            cv_ptr = cv_bridge::toCvCopy(msg, sensor_msgs::image_encodings::BGR8);
        } catch (cv_bridge::Exception& e) {
            RCLCPP_ERROR(this->get_logger(), "cv_bridge 翻车: %s", e.what());
            return;
        }

        cv::Mat img = cv_ptr->image;
        cv::Mat resized_img;
        
        // 2. 图像预处理 (缩放到 640x640，HWC 转 CHW，归一化)
        cv::resize(img, resized_img, cv::Size(INPUT_W, INPUT_H));
        std::vector<float> input_data(1 * 3 * INPUT_H * INPUT_W);
        // 这里省略了具体的 for 循环像素搬运代码，把 resized_img 塞进 input_data

        // 3. 把 CPU 数据拷贝到 GPU 显存
        cudaMemcpyAsync(buffers_[0], input_data.data(), input_data.size() * sizeof(float), cudaMemcpyHostToDevice, stream_);

        // 4. ⚡️ 极速推理 (调用 Tensor Core) ⚡️
        // TRT 10 最新语法：绑定显存地址并执行
        context_->setTensorAddress("images", buffers_[0]); 
        context_->setTensorAddress("output0", buffers_[1]);
        context_->enqueueV3(stream_); // 瞬间完成计算

        // 5. 把结果从 GPU 拷贝回 CPU 内存
        std::vector<float> output_data(OUTPUT_SIZE);
        cudaMemcpyAsync(output_data.data(), buffers_[1], output_data.size() * sizeof(float), cudaMemcpyDeviceToHost, stream_);
        cudaStreamSynchronize(stream_); // 阻塞等待拷贝完成

        // ==========================================
        // 第三斧：后处理与发布
        // ==========================================
        // 这里是你写 NMS（非极大值抑制）的地方
        // 解析 output_data，找到置信度最高的“毛球”坐标 (x, y, w, h)
        
        // 假设我们找到了毛球，直接在 OpenCV 图像上画一个骚气的红色瞄准框
        cv::Rect bbox(100, 100, 200, 200); // 假数据示例
        cv::rectangle(img, bbox, cv::Scalar(0, 0, 255), 3);
        cv::putText(img, "Hairball 99%", cv::Point(100, 90), cv::FONT_HERSHEY_SIMPLEX, 1, cv::Scalar(0, 0, 255), 2);

        // 把画好框的 OpenCV 图像转回 ROS 消息并发布出去！
        sensor_msgs::msg::Image::SharedPtr out_msg = cv_bridge::CvImage(msg->header, "bgr8", img).toImageMsg();
        publisher_->publish(*out_msg);
    }
};

int main(int argc, char * argv[]) {
    // ROS 2 节点初始化
    rclcpp::init(argc, argv);
    rclcpp::spin(std::make_shared<YoloTrtNode>());
    rclcpp::shutdown();
    return 0;
}