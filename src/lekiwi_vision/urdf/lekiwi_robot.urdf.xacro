<?xml version="1.0"?>
<robot name="lekiwi_full_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- ========================================== -->
    <!-- 0. 定义专属调色板，告别红屏报警 -->
    <!-- ========================================== -->
    <material name="LekiwiDarkGrey">
        <color rgba="0.3 0.3 0.3 1.0"/>
    </material>
    <material name="LekiwiBlack">
        <color rgba="0.1 0.1 0.1 1.0"/>
    </material>
    <material name="LekiwiWhite">
        <color rgba="0.9 0.9 0.9 1.0"/>
    </material>

    <!-- 导入官方底盘 -->
    <xacro:include filename="$(find lekiwi_vision)/urdf/LeKiwi.urdf" />

    <link name="base_footprint"/>

    <joint name="footprint_to_chassis" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_plate_layer1-v5"/>
        <origin xyz="0 0 0.05" rpy="0 0 0"/> 
    </joint>

    <!-- 引入lekiwi_vision包中的SO-101机械臂URDF模型 -->
    <xacro:include filename="$(find lekiwi_vision)/urdf/so101_arm.urdf" />

    <!-- 定义机械臂与底盘之间的固定关节 -->
    <joint name="arm_to_base_joint" type="fixed">
        <parent link="base_plate_layer2-v3"/>
        <child link="base_link"/>
        <origin xyz="0.00 0.04 0.007" rpy="0 0 1.57"/> 
    </joint>

    <link name="riser_base_link">
        <visual>
            <geometry>
                <mesh filename="package://lekiwi_vision/meshes/riser_base.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="LekiwiBlack"/> </visual>
    </link>

    <joint name="chassis_to_riser" type="fixed">
        <parent link="base_plate_layer2-v3"/>
        <child link="riser_base_link"/>
        <origin xyz="-0.06 -0.037 0.007" rpy="0 0 0"/> 
    </joint>

    <link name="pillar_link">
        <visual>
            <geometry>
                <mesh filename="package://lekiwi_vision/meshes/my_pillar.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="LekiwiDarkGrey"/>
        </visual>
    </link>

    <joint name="riser_to_pillar" type="fixed">
        <parent link="riser_base_link"/>
        <child link="pillar_link"/>
        <origin xyz="0.036 0.007 0.05" rpy="0 -1.57 0.5236"/> 
    </joint>

    <!-- ========================================== -->
    <!-- 2. 舵机固定件 (Servo Mount) -->
    <!-- ========================================== -->
    <link name="servo_mount_link">
        <visual>
            <geometry>
                <mesh filename="package://lekiwi_vision/meshes/my_servo_mount.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="LekiwiBlack"/>
        </visual>
    </link>

    <joint name="pillar_to_mount" type="fixed">
        <parent link="pillar_link"/>
        <child link="servo_mount_link"/>
        <origin xyz="0.25 0 0.025" rpy="0 1.57 0"/> 
    </joint>

    <!-- ========================================== -->
    <!-- 3. ST3215 舵机本体 (Servo Body) -->
    <!-- ========================================== -->
    <link name="st3215_servo_link">
        <visual>
            <geometry>
                <mesh filename="package://lekiwi_vision/meshes/ST3215_Servo_Motor-v1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="LekiwiWhite"/>
        </visual>
    </link>

    <joint name="mount_to_servo" type="fixed">
        <parent link="servo_mount_link"/>
        <child link="st3215_servo_link"/>
        <origin xyz="-0.01 0.00 0.02" rpy="3.14 0 -1.57"/> 
    </joint>

    <!-- ========================================== -->
    <!-- 4. 相机固定件 (Camera Mount - 这是打在舵机上的塑料件) -->
    <!-- ========================================== -->
    <!-- 💥 修改点：名字从 camera_link 改成了 camera_mount_link -->
    <link name="camera_mount_link">
        <visual>
            <origin xyz="0.0 0.0 -0.02" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://lekiwi_vision/meshes/my_camera_mount.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="LekiwiBlack"/>
        </visual>
    </link>

    <!-- 💥 核心云台关节：舵机带动【固定件】转动 -->
    <joint name="camera_pitch_joint" type="revolute">
        <parent link="st3215_servo_link"/>
        <child link="camera_mount_link"/> <!-- 指向改名后的固定件 -->
        <origin xyz="-0.025 -0.01 0.005" rpy="1.57 0 -1.57"/>
        <axis xyz="1 0 0"/>
        <limit lower="-0.785" upper="0.785" effort="10" velocity="1"/>
    </joint>

    <!-- ========================================== -->
    <!-- 5. RealSense 相机本体 (Camera Body) -->
    <!-- ========================================== -->
   <link name="camera_link">
        <visual>
            <origin xyz="0 -0.04 0" rpy="-1.57 0 -1.57"/> 
            <geometry>
                <mesh filename="package://lekiwi_vision/meshes/d435.dae" />
            </geometry>
        </visual>
        
        <collision>
            <origin xyz="0 -0.04 0" rpy="-1.57 0 -1.57"/>
            <geometry>
                <box size="0.025 0.090 0.025"/>
            </geometry>
        </collision>
    </link>

    <!-- 💥 新增关节：用螺丝把【相机】锁死在【固定件】上！ -->
    <joint name="mount_to_camera_joint" type="fixed">
        <parent link="camera_mount_link"/> <!-- 爹是固定件 -->
        <child link="camera_link"/>        <!-- 儿子是相机 -->
        <!-- ⚠️ 亢哥注意：这里的 xyz 和 rpy 是相机相对于固定件螺丝孔的偏移量 -->
        <!-- 你需要在 RViz 里微调这 6 个数字，让银色相机刚好贴合在你的黑色塑料支架上 -->
        <origin xyz="-0.04 0 0.061" rpy="0 -1.57 1.57"/> 
    </joint>

</robot>